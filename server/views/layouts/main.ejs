<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title %></title>
    <link rel="stylesheet" href="/css/main.css" />
    <link rel="stylesheet" href="/css/table.css" />
    <link rel="stylesheet" href="/css/modal.css" />
    <link rel="stylesheet" href="/css/pagination.css"/>
    <link rel="stylesheet" href="/css/btn.css" />
  </head>
  <body>
    <nav class="nav">
      <a href="/movies" class="nav__link <%= path === '/movies' ? 'nav__link--active' : '' %>">Movies</a>
      <a href="/customers" class="nav__link <%= path === '/customers' ? 'nav__link--active' : '' %>">Customers</a>
      <a href="/tickets" class="nav__link <%= path === '/tickets' ? 'nav__link--active' : '' %>">Tickets</a>
    </nav>
    <main class="main">
      <%- body %>
    </main>
    <script src="/socket.io/socket.io.js"></script>
    <script>
      document.querySelectorAll('.c-modal').forEach(dialog => {
        dialog.addEventListener('close', () => {
          const iframe = dialog.querySelector('iframe');
          if (iframe) iframe.src = iframe.src;
        });
      });

      const socket = io();

      let submitting = false;

      document.querySelectorAll('form').forEach(form => {
        form.addEventListener('submit', () => submitting = true);
      });

      const reloadOn = [
        'movie:created', 'movie:updated', 'movie:deleted',
        'customer:created', 'customer:updated', 'customer:deleted',
        'ticket:created', 'ticket:updated', 'ticket:deleted',
      ];

      reloadOn.forEach(event => socket.on(event, () => {
        if (!submitting) location.reload();
      }));
    </script>
  </body>
</html>
