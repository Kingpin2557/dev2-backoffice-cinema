<section>
  <% if (error) { %>
    <p style="color: red;">Error: <%= error %></p>
  <% } else if (tickets.length === 0) { %>
    <p>No tickets found.</p>
  <% } else { %>
    <table>
      <thead>
        <tr>
          <th scope="col">ID</th>
          <th scope="col">Customer ID</th>
          <th scope="col">Seat ID</th>
          <th scope="col">Showtime ID</th>
          <th scope="col">Purchase date</th>
          <th scope="col">Price</th>
          <th scope="col">Type</th>
        </tr>
      </thead>
      <tbody>
        <% tickets.forEach(ticket => { %>
          <tr>
            <td><%= ticket.id %></td>
            <td><%= ticket.customerId %></td>
            <td><%= ticket.seatId %></td>
            <td><%= ticket.showtimeId %></td>
            <td><%= new Date(ticket.purchaseDate).toLocaleDateString() %></td>
            <td><%= ticket.price %></td>
            <td><%= ticket.type %></td>
          </tr>
        <% }) %>
        <% for (let i = 0; i < emptyRows; i++) { %>
          <tr class="table__row--empty">
            <td>&nbsp;</td><td></td><td></td><td></td><td></td><td></td><td></td>
          </tr>
        <% } %>
      </tbody>
    </table>
    <%- include('partials/pagination', { page: page, totalPages: totalPages , path: path }) %>
  <% } %>
</section>
